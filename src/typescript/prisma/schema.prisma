generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lamp {
  id        String    @id @default(uuid()) @db.Uuid
  isOn      Boolean   @map("is_on") @db.Boolean
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // Prisma does not support partial index WHERE clauses in schema declarations.
  // These @@index entries keep Prisma's schema diffing aware of the indexes; the migration
  // SQL file manually adds the WHERE deleted_at IS NULL predicate to make them partial.
  @@index([createdAt, id], name: "idx_lamps_active_created_at_id")
  @@index([isOn], name: "idx_lamps_active_is_on")
  @@map("lamps")
}
