generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lamp {
  id        String    @id @default(uuid()) @db.Uuid
  isOn      Boolean   @map("is_on") @db.Boolean
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // Partial indexes (WHERE deleted_at IS NULL) are managed via raw SQL in the migration file
  // as Prisma does not support partial index WHERE clauses in schema declarations.
  // idx_lamps_active_created_at_id ON lamps (created_at ASC, id ASC) WHERE deleted_at IS NULL
  // idx_lamps_active_is_on ON lamps (is_on) WHERE deleted_at IS NULL
  @@map("lamps")
}
